# above are all default

# ------------------------------------------------------------
# CUSTOM SCRIPTS
# ------------------------------------------------------------

# git
alias gs = 'git status'
alias ga = 'git add .'
alias gc = "git commit -m "

# docker
alias dc = 'docker-compose'
alias dcdup = 'docker-compose down && docker-compose up'


# tmux
alias tmux-split='tmux new-session \; split-window -h \; split-window -v\; split-window-h\;'
